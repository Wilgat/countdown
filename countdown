# GENERAL PURPOSE:
# Adds ~/.local/bin to the user's shell configuration for bash, zsh, and fish.
# Works even if the user is currently using a different shell.
#
# !!! DO NOT MODIFY OR SIMPLIFY !!!
# Designed to be reusable in other projects.
# =============================================================================

add_to_shell_path() {
    local added=0
    local shell_config="N/A"

    # Bash
    local bashrc="${HOME}/.bashrc"
    if [ -f "$bashrc" ]; then
        if [ "$shell_config" = "N/A" ]; then
            shell_config="${bashrc}"
        else
            shell_config="${shell_config} ${bashrc}"
        fi
        if ! grep -qF 'export PATH="$HOME/.local/bin:$PATH"' "$bashrc" 2>/dev/null; then
            printf "\n# Added by %s installer (%s)\n" "$APP_NAME" "$VERSION" >> "$bashrc"
            printf 'export PATH="$HOME/.local/bin:$PATH"\n' >> "$bashrc"
            added=1
            if [ "${JSON}" -eq 0 ]; then
                msg "→ Added ~/.local/bin to PATH for bash"
            fi
        fi
    fi

    # Zsh
    local zshrc="${HOME}/.zshrc"
    if [ -f "$zshrc" ]; then
        if [ "$shell_config" = "N/A" ]; then
            shell_config="${zshrc}"
        else
            shell_config="${shell_config} ${zshrc}"
        fi
        if ! grep -qF 'export PATH="$HOME/.local/bin:$PATH"' "$zshrc" 2>/dev/null; then
            printf "\n# Added by %s installer (%s)\n" "$APP_NAME" "$VERSION" >> "$zshrc"
            printf 'export PATH="$HOME/.local/bin:$PATH"\n' >> "$zshrc"
            added=1
            if [ "${JSON}" -eq 0 ]; then
                msg "→ Added ~/.local/bin to PATH for zsh"
            fi
        fi
    fi

    # Fish
    local fish_config="${HOME}/.config/fish/config.fish"
    if [ -d "${HOME}/.config/fish" ] || mkdir -p "${HOME}/.config/fish" 2>/dev/null; then
        if [ "$shell_config" = "N/A" ]; then
            shell_config="${fish_config}"
        else
            shell_config="${shell_config} ${fish_config}"
        fi
        if [ -f "$fish_config" ] && grep -qF 'set -gx PATH $HOME/.local/bin $PATH' "$fish_config" 2>/dev/null; then
            : # already present
        else
            printf "\n# Added by %s installer (%s)\n" "$APP_NAME" "$VERSION" >> "$fish_config"
            printf 'set -gx PATH $HOME/.local/bin $PATH\n' >> "$fish_config"
            added=1
            if [ "${JSON}" -eq 0 ]; then
                msg "→ Added ~/.local/bin to PATH for fish shell"
            fi
        fi
    fi

    if [ "$added" -eq 1 ] && [ "${JSON}" -eq 0 ]; then
        msg "→ Restart your terminal or run: source ${shell_config}"
    fi
}

# =============================================================================
# SELF-INSTALL LOGIC - UPDATED TO v2 (April 2026)
# =============================================================================
#
# CRITICAL DEFENSIVE FUNCTION - DO NOT SIMPLIFY, REMOVE, OR REFACTOR
#
# New in v2 (perform_self_install_v2):
#   1. If environment variable CHECKSUM=<sha256> is set (e.g. exported by user or CI),
#      the script will:
#        • Download the script from ${SCRIPT_URL}
#        • Verify the downloaded content against the provided CHECKSUM using sha256sum
#        • Only proceed with installation if the checksum matches exactly
#        • This allows users/CI to pin a known-good version and protect against
#          MITM, compromised GitHub raw, or network tampering.
#
#   2. If CHECKSUM is NOT set (normal interactive/one-liner usage):
#        • First attempt: curl ${SCRIPT_URL} (the script itself)
#        • Second attempt: also fetch ${SCRIPT_URL}.sha256 (if HTTP 200)
#        • If the .sha256 file exists and is valid, verify the downloaded script
#          with "sha256sum -c"
#        • If verification fails → die with clear error (incorrect checksum)
#        • If no .sha256 file or verification skipped → proceed (backward compatible)
#
# Why this v2 protection is needed (Defensive Reasoning):
#   • The classic `curl | sh` pattern is convenient but inherently risky.
#   • GitHub raw content can be tampered with via account compromise, supply-chain attack,
#     or transient network interception.
#   • Providing both an explicit CHECKSUM env var and automatic .sha256 lookup
#     significantly reduces the attack surface for one-command installs.
#   • Maintains full backward compatibility for users who do not provide CHECKSUM.
#   • Aligns with CIAO-Lite "Caution" and "Over-protect" principles.
#   • Prevents silent installation of malicious code — fail loudly on checksum mismatch.
#
# Updated from previous version:
#   • Old: perform_self_install() performed blind download + move.
#   • New: perform_self_install_v2() adds layered checksum verification while keeping
#     the rest of the installation logic (temp file, permissions, PATH handling) identical.
#   • The function name was deliberately changed to perform_self_install_v2 to clearly
#     signal the security upgrade. Old name is preserved in comments for reference.
#   • All other self-update / self-uninstall logic continues to call the v2 version.
#
# !!! THIS IS THE SINGLE SOURCE OF TRUTH FOR SELF-INSTALLATION !!!
# !!! DO NOT RENAME BACK, DO NOT MERGE WITH OTHER FUNCTIONS !!!
# !!! ALWAYS CALL perform_self_install_v2() FOR NEW INSTALLS !!!
# Shebang remains #!/bin/sh - defensive and portable.
# Repeated safe defaults and heavy comments are intentional.
#
# Aligned with https://github.com/Wilgat/ciao
# Last aligned: 20 April 2026
# =============================================================================

perform_self_install_v2() {
    : "${GLOBAL_BIN:=/usr/local/bin}"
    : "${USER_BIN:=${HOME}/.local/bin}"
    : "${INSTALL_PATH:=${GLOBAL_BIN}/${APP_NAME}}"

    if [ "$(id -u)" -eq 0 ]; then
        IS_ROOT=1
        INSTALL_PATH="${GLOBAL_BIN}/${APP_NAME}"
    else
        IS_ROOT=0
        INSTALL_PATH="${USER_BIN}/${APP_NAME}"
    fi

    if [ -z "$REMOTE_VERSION" ]; then
        REMOTE_VERSION=${VERSION}
    fi

    if [ "${JSON}" -eq 0 ]; then
        info "Starting installation of ${APP_NAME} ${REMOTE_VERSION}..."
    fi

    if is_installed && [ "${FORCE_REINSTALL}" -eq 0 ]; then
        if [ "${JSON}" -eq 1 ]; then
            output_json "success" "message" "${APP_NAME} is already installed."
        else
            success "${APP_NAME} is already installed. Use --force to override."
        fi
        return 0
    fi

    # Create correct target directory (root vs user)
    if [ "$IS_ROOT" -eq 1 ]; then
        if ! mkdir -p "${GLOBAL_BIN}" 2>/dev/null; then
            if [ "${JSON}" -eq 1 ]; then
                output_json_error "Failed to create ${GLOBAL_BIN}" "io_error"
            else
                error "Failed to create ${GLOBAL_BIN}"
            fi
            return 1
        fi
    else
        if ! mkdir -p "${USER_BIN}" 2>/dev/null; then
            if [ "${JSON}" -eq 1 ]; then
                output_json_error "Failed to create ${USER_BIN}" "io_error"
            else
                error "Failed to create ${USER_BIN}"
            fi
            return 1
        fi
    fi

    local tmp_file
    tmp_file=$(mktemp -t "${APP_NAME}.XXXXXX") || {
        if [ "${JSON}" -eq 1 ]; then
            output_json_error "Failed to create temporary file" "io_error"
        else
            error "Failed to create temporary file"
        fi
        return 1
    }

    if [ "${JSON}" -eq 0 ]; then
        info "Downloading ${APP_NAME} from GitHub..."
    fi

    # =============================================================================
    # CHECKSUM VERIFICATION LAYER (v2 security upgrade)
    # =============================================================================
    local downloaded_checksum_ok=0

    if [ -n "${CHECKSUM:-}" ]; then
        # Explicit CHECKSUM provided by user/CI → strict verification
        if [ "${JSON}" -eq 0 ]; then
            info "Verifying download against provided CHECKSUM..."
        fi

        if command -v curl >/dev/null 2>&1; then
            curl -fsSL "${SCRIPT_URL}" -o "${tmp_file}" || {
                rm -f "${tmp_file}"
                if [ "${JSON}" -eq 1 ]; then
                    output_json_error "Download failed (curl)" "network_error"
                else
                    error "Download failed (curl)"
                fi
                return 1
            }
        elif command -v wget >/dev/null 2>&1; then
            wget -qO "${tmp_file}" "${SCRIPT_URL}" || {
                rm -f "${tmp_file}"
                if [ "${JSON}" -eq 1 ]; then
                    output_json_error "Download failed (wget)" "network_error"
                else
                    error "Download failed (wget)"
                fi
                return 1
            }
        else
            rm -f "${tmp_file}"
            if [ "${JSON}" -eq 1 ]; then
                output_json_error "Neither curl nor wget found" "missing_dependency"
            else
                error "Neither curl nor wget found"
            fi
            return 1
        fi

        # Verify provided CHECKSUM
        if printf '%s  %s\n' "${CHECKSUM}" "${tmp_file}" | sha256sum -c - >/dev/null 2>&1; then
            downloaded_checksum_ok=1
            if [ "${JSON}" -eq 0 ]; then
                success "Checksum verification passed (user-provided CHECKSUM)."
            fi
        else
            rm -f "${tmp_file}"
            if [ "${JSON}" -eq 1 ]; then
                output_json_error "Checksum verification failed (provided CHECKSUM does not match)" "checksum_mismatch"
            else
                die "Checksum verification failed. The downloaded file does not match the provided CHECKSUM. Installation aborted for security."
            fi
            return 1
        fi

    else
        # No explicit CHECKSUM → try automatic .sha256 file (best-effort)
        if [ "${JSON}" -eq 0 ]; then
            info "No CHECKSUM provided → attempting automatic verification via ${SCRIPT_URL}.sha256"
        fi

        if command -v curl >/dev/null 2>&1; then
            # Primary download
            curl -fsSL "${SCRIPT_URL}" -o "${tmp_file}" || {
                rm -f "${tmp_file}"
                if [ "${JSON}" -eq 1 ]; then
                    output_json_error "Download failed (curl)" "network_error"
                else
                    error "Download failed (curl)"
                fi
                return 1
            }

            # Try to fetch .sha256 sidecar
            local sha_file
            sha_file=$(mktemp -t "${APP_NAME}.sha256.XXXXXX") || {
                rm -f "${tmp_file}"
                return 1
            }

            if curl -fsSL -w "%{http_code}" "${SCRIPT_URL}.sha256" -o "${sha_file}" 2>/dev/null | grep -q "^200"; then
                if sha256sum -c "${sha_file}" --status 2>/dev/null < "${tmp_file}"; then
                    downloaded_checksum_ok=1
                    if [ "${JSON}" -eq 0 ]; then
                        success "Automatic checksum verification passed (${SCRIPT_URL}.sha256)."
                    fi
                else
                    rm -f "${tmp_file}" "${sha_file}"
                    if [ "${JSON}" -eq 1 ]; then
                        output_json_error "Automatic checksum verification failed" "checksum_mismatch"
                    else
                        die "Checksum verification failed (mismatch with ${SCRIPT_URL}.sha256). Installation aborted for security."
                    fi
                    return 1
                fi
            else
                # No .sha256 available → proceed without verification (backward compatible)
                if [ "${JSON}" -eq 0 ]; then
                    warn "No .sha256 file found at ${SCRIPT_URL}.sha256 → continuing without automatic verification."
                fi
            fi
            rm -f "${sha_file}" 2>/dev/null || true

        elif command -v wget >/dev/null 2>&1; then
            # Similar logic for wget (kept minimal and defensive)
            wget -qO "${tmp_file}" "${SCRIPT_URL}" || {
                rm -f "${tmp_file}"
                if [ "${JSON}" -eq 1 ]; then
                    output_json_error "Download failed (wget)" "network_error"
                else
                    error "Download failed (wget)"
                fi
                return 1
            }

            local sha_file
            sha_file=$(mktemp -t "${APP_NAME}.sha256.XXXXXX") || {
                rm -f "${tmp_file}"
                return 1
            }

            if wget -q --server-response "${SCRIPT_URL}.sha256" -O "${sha_file}" 2>&1 | grep -q "HTTP/1.1 200"; then
                if sha256sum -c "${sha_file}" --status 2>/dev/null < "${tmp_file}"; then
                    downloaded_checksum_ok=1
                    if [ "${JSON}" -eq 0 ]; then
                        success "Automatic checksum verification passed."
                    fi
                else
                    rm -f "${tmp_file}" "${sha_file}"
                    if [ "${JSON}" -eq 1 ]; then
                        output_json_error "Automatic checksum verification failed" "checksum_mismatch"
                    else
                        die "Checksum verification failed. Installation aborted for security."
                    fi
                    return 1
                fi
            else
                if [ "${JSON}" -eq 0 ]; then
                    warn "No .sha256 file found → continuing without automatic verification."
                fi
            fi
            rm -f "${sha_file}" 2>/dev/null || true
        else
            rm -f "${tmp_file}"
            if [ "${JSON}" -eq 1 ]; then
                output_json_error "Neither curl nor wget found" "missing_dependency"
            else
                error "Neither curl nor wget found"
            fi
            return 1
        fi
    fi

    # Final safety: if we reached here without explicit failure, file is in tmp_file
    chmod +x "${tmp_file}" 2>/dev/null || true

    rm -f "${INSTALL_PATH}" 2>/dev/null
    if ! mv "${tmp_file}" "${INSTALL_PATH}" 2>/dev/null; then
        rm -f "${tmp_file}"
        if [ "${JSON}" -eq 1 ]; then
            output_json_error "Failed to move to ${INSTALL_PATH}" "io_error"
        else
            error "Failed to move to ${INSTALL_PATH}"
        fi
        return 1
    fi

    # Add ~/.local/bin to PATH for normal user installs
    if [ "$IS_ROOT" -eq 0 ]; then
        add_to_shell_path
    fi
    
    if [ "${JSON}" -eq 1 ]; then
        output_json "success" "message" "${APP_NAME} ${REMOTE_VERSION} successfully installed to ${INSTALL_PATH}"
    else
        success "${APP_NAME} ${REMOTE_VERSION} successfully installed to ${INSTALL_PATH}"
        if [ "${downloaded_checksum_ok}" -eq 1 ]; then
            success "✓ Download was cryptographically verified."
        fi
    fi
    return 0
}

# =============================================================================
# prompt_yes_no() - Defensive interactive yes/no confirmation prompt
# =============================================================================
#
# GENERAL PURPOSE:
# Displays a message and waits for (y/N) confirmation.
# Returns 0 if user says yes, returns 1 (non-zero) if user says no or cancels.
#
# CRITICAL DEFENSIVE RULES (DO NOT VIOLATE):
# 1. Must ALWAYS go through single source of truth (msg_n + output_text)
# 2. Must respect --quiet and --json (never show prompt in those modes)
# 3. Must NEVER use raw printf/echo for user-visible text
# 4. Must work correctly in non-interactive / curl | sh environments
# 5. Must preserve TTY detection and color handling via output_text
# 6. This is the SINGLE SOURCE OF TRUTH for all yes/no confirmations in the project.
#
# !!! DO NOT MODIFY OR SIMPLIFY THIS FUNCTION !!!
# Past AI assistants have repeatedly replaced this kind of prompt with
# raw printf + read, breaking consistency with output_text(), --quiet,
# --json, TTY detection, and the overall defensive design.
#
# This helper exists specifically to prevent that regression and to enforce
# CIAO-Lite principles of Caution, Intentionality, and Over-protect.
#
# Last reviewed & aligned: April 2026
# =============================================================================

prompt_yes_no() {
    # --- Safe Variable Defaults ----
    # Defensive defaults - never assume globals are set
    : "${JSON:=0}"
    : "${QUIET:=0}"

    local message="$1"

    # Never show prompt in quiet or json mode
    if [ "${JSON}" -eq 1 ] || [ "${QUIET}" -eq 1 ]; then
        return 1   # treat as "no" in non-interactive modes
    fi

    # Must be interactive TTY
    if ! [ -t 0 ] || ! [ -t 1 ]; then
        return 1
    fi

    msg_n "${message}"
    empty_line
    msg_n "Continue? (y/N): "

    local answer=""
    read -r answer || true

    case "$answer" in
        [Yy]*|[Yy][Ee][Ss]*)
            return 0
            ;;
        *)
            return 1
            ;;
    esac
}

# =============================================================================
# maybe_install_v3() - Friendly installation prompt
# =============================================================================
#
# Respects both --quiet and --json modes.
# In JSON mode we skip the interactive prompt entirely.
# Now uses prompt_yes_no() as single source of truth for confirmation.
#
# !!! DO NOT MODIFY OR SIMPLIFY !!!
# Designed to be reusable in other projects.
#
# Last aligned: 20 April 2026
# =============================================================================

maybe_install_v3() {
    if is_installed && [ "${FORCE_REINSTALL}" -eq 0 ]; then
        return 0
    fi

    # In JSON mode or quiet mode we do not show interactive prompts
    if [ "${JSON}" -eq 1 ] || [ "${QUIET}" -eq 1 ]; then
        return 0
    fi

    empty_line
    msg "Note: '${APP_NAME}' is not installed yet."
    msg "     Version: ${VERSION}"
    empty_line
    msg "Recommended installation command:"
    empty_line

    if [ "$IS_ROOT" -eq 1 ]; then
        msg "     sudo curl -fsSL ${SCRIPT_URL} | sudo ${SH}"
    else
        msg "     curl -fsSL ${SCRIPT_URL} | ${SH}"
    fi
    empty_line

    # Use single source of truth for the yes/no prompt
    if prompt_yes_no "Install ${APP_NAME} ${VERSION} now?"; then
        perform_self_install_v2
        exit 0
    else
        msg "Installation skipped by user."
        return 0
    fi
}


# =============================================================================
# show_about_pomo() - Display diagnostic information about the current environment
# =============================================================================
#
# GENERAL PURPOSE:
# Shows detailed diagnostic information: version, installation status (global + local),
# current shell, TTY/interactive status, user, and helpful next steps.
#
# Fully respects --quiet and --json modes.
# In JSON mode: outputs exactly ONE clean, machine-readable JSON object.
# In quiet mode: prints nothing.
#
# This function provides real value to users (unlike the previous overly simple version)
# and should be kept in sync with the overall CIAO design and README.md.
#
# !!! DO NOT MODIFY OR SIMPLIFY THIS FUNCTION !!!
# Designed to be reusable in other CIAO projects.
# Last reviewed: April 2026
# =============================================================================

show_about_pomo() {
    if [ "${JSON}" -eq 1 ]; then
        # === JSON MODE - Clean, machine-friendly output ===
        local installed="false"
        is_installed && installed="true"

        local global_ver="not found"
        if [ -x "${GLOBAL_BIN}/${APP_NAME}" ]; then
            global_ver=$(grep '^VERSION="' "${GLOBAL_BIN}/${APP_NAME}" 2>/dev/null | cut -d'"' -f2 || echo "unknown")
        fi

        local local_ver="not found"
        if [ -x "${USER_BIN}/${APP_NAME}" ]; then
            local_ver=$(grep '^VERSION="' "${USER_BIN}/${APP_NAME}" 2>/dev/null | cut -d'"' -f2 || echo "unknown")
        fi

        # Improved shell detection to avoid showing the script name itself
        local current_shell="unknown"
        current_shell=$(ps -p $$ -o comm= 2>/dev/null | tr -d '()' || echo "unknown")
        
        if [ "$current_shell" = "${APP_NAME}" ] || [ "$current_shell" = "sh" ] || \
           [ "$current_shell" = "dash" ] || [ "$current_shell" = "ash" ]; then
            local parent_pid
            parent_pid=$(ps -p $$ -o ppid= 2>/dev/null | tr -d ' ')
            if [ -n "$parent_pid" ]; then
                current_shell=$(ps -p "$parent_pid" -o comm= 2>/dev/null | tr -d '()' || echo "$current_shell")
            fi
        fi

        local interactive="false"
        [ -t 1 ] && interactive="true"

        output_json "about" "" \
            "app" "${APP_NAME}" \
            "version" "${VERSION}" \
            "installed" "${installed}" \
            "global_version" "${global_ver}" \
            "local_version" "${local_ver}" \
            "shell" "${current_shell}" \
            "interactive" "${interactive}" \
            "user" "${USERNAME}" \
            "storage_dir" "$(resolve_storage 2>/dev/null || echo "unknown")"

        return 0
    fi

    # === Normal Human-readable Mode ===
    [ "${QUIET}" -eq 1 ] && return 0

    msg "=== ${APP_NAME} ${VERSION} - About / Diagnostics ==="
    empty_line

    # Installation status
    if is_installed; then
        success "${APP_NAME} is properly installed."
    else
        warn "${APP_NAME} is NOT installed in your PATH."
        if [ -t 1 ]; then
            msg "   Recommended one-liner:"
            msg "     curl -fsSL ${SCRIPT_URL} | sh"
        else
            msg "   Recommended: curl -fsSL ${SCRIPT_URL} | sh"
        fi
    fi

    empty_line

    # Global vs Local installation details
    if [ -x "${GLOBAL_BIN}/${APP_NAME}" ]; then
        global_ver=$(grep '^VERSION="' "${GLOBAL_BIN}/${APP_NAME}" 2>/dev/null | cut -d'"' -f2 || echo "unknown")
        msg "Global install  (${GLOBAL_BIN}/${APP_NAME}):   ${global_ver}"
    else
        msg "Global install  (${GLOBAL_BIN}/${APP_NAME}):   not found"
    fi

    if [ -x "${USER_BIN}/${APP_NAME}" ]; then
        local_ver=$(grep '^VERSION="' "${USER_BIN}/${APP_NAME}" 2>/dev/null | cut -d'"' -f2 || echo "unknown")
        msg "Local install   (${USER_BIN}/${APP_NAME}):    ${local_ver}"
    else
        msg "Local install   (${USER_BIN}/${APP_NAME}):    not found"
    fi

    empty_line

    # Shell & Environment
    local current_shell="unknown"
    current_shell=$(ps -p $$ -o comm= 2>/dev/null | tr -d '()' || echo "unknown")
    
    if [ "$current_shell" = "${APP_NAME}" ] || [ "$current_shell" = "sh" ] || \
       [ "$current_shell" = "dash" ] || [ "$current_shell" = "ash" ]; then
        local parent_pid
        parent_pid=$(ps -p $$ -o ppid= 2>/dev/null | tr -d ' ')
        if [ -n "$parent_pid" ]; then
            current_shell=$(ps -p "$parent_pid" -o comm= 2>/dev/null | tr -d '()' || echo "$current_shell")
        fi
    fi

    msg "Current shell:     ${current_shell}"
    msg "User:              ${USERNAME}"

    if [ -t 1 ]; then
        msg "TTY / Interactive: yes"
    else
        msg "TTY / Interactive: no (non-interactive / scripted mode)"
    fi

    msg "Storage directory: $(resolve_storage 2>/dev/null || echo "unknown")"

    empty_line
    msg "Useful commands:"
    msg "   ${APP_NAME} help          → Full usage and examples"
    msg "   ${APP_NAME} self-update   → Update to latest version"
    msg "   ${APP_NAME} self-uninstall → Clean removal from system"
    msg "   ${APP_NAME} --json        → Machine-readable output"

    empty_line
    msg "Run '${APP_NAME} help' for complete usage information."
}

# =============================================================================
# show_countdown_help() - Display help information for pomo
# =============================================================================
#
# Shows usage, available commands, examples, and theme information.
# Fully respects --quiet and --json modes.
#
# In --json mode: returns a minimal success object instead of long text.
# In --quiet mode: prints nothing (silent).
#
# This is the user-facing help text and should be kept in sync with the README.md.
# =============================================================================

show_countdown_help() {
    if [ "${JSON}" -eq 1 ]; then
        # JSON mode: never output long help text
        output_json "success" "Help text available in human-readable mode. Run without --json." \
            "command" "help" \
            "note" "Use --json with other commands (status, list, stats, about, etc.) for machine output."
        return 0
    fi

    if [ "${QUIET}" -eq 1 ]; then
        # Quiet/silent mode: suppress help completely
        return 0
    fi

    cat << EOF
${APP_NAME} – version ${VERSION} - Lightweight per-user named countdown timers

Usage:
  ${APP_NAME} start [--persist] <name> <duration>   Start a countdown
  ${APP_NAME} status [--persist] [name]             Show remaining time
  ${APP_NAME} stop [--persist] [name]               Stop and show remaining time
  ${APP_NAME} kill|reset [--persist] [name]         Discard countdown
  ${APP_NAME} list [--persist]                      List all running countdowns

  ${APP_NAME} about                                 Show diagnostics
  ${APP_NAME} version                               Show version
  ${APP_NAME} help                                  This help

Examples:
  ${APP_NAME} start 25m                    # Start default countdown for 25 minutes
  ${APP_NAME} start work 1h30m             # Start named countdown
  ${APP_NAME} start --persist pomodoro 25m # Persistent Pomodoro timer
  ${APP_NAME} start break 5m

  ${APP_NAME} status work
  ${APP_NAME} stop work
  ${APP_NAME} list
  ${APP_NAME} list --persist

Duration formats supported:
  25m      → 25 minutes
  90s      → 90 seconds
  1h       → 1 hour
  1h30m    → 1 hour 30 minutes
  2h15m45s → 2 hours 15 min 45 sec
  45       → 45 seconds (plain number)

Options:
  --persist     Store countdown in persistent storage (~/.cache/countdown/)
  --quiet, -q   Suppress non-error messages
  --json        Output in machine-readable JSON format (implies --quiet)

Note: 'timer' and 'countdown' are separate tools.
      Use 'timer' for simple count-up timers.
EOF
}


# =============================================================================
# resolve_app_base_dir() - Central storage resolver with full fallback
# =============================================================================
#
# SINGLE SOURCE OF TRUTH for all ${APP_NAME} storage decisions.
# Handles missing /dev/shm, missing $HOME, and ensures we always have
# a writable location or die() with clear message.
#
# Priority for volatile mode:
#   1. /dev/shm          (fastest, RAM)
#   2. /tmp              (standard fallback, almost always available)
#   3. /tmp/${APP_NAME}_${USERNAME}  (safe per-user subdir when $HOME is missing)
#
# For persistent mode: always tries XDG_CACHE_HOME → ~/.cache → /tmp/${APP_NAME}_${USERNAME}
#
# !!! DO NOT MODIFY OR DUPLICATE THIS LOGIC !!!
# All ${APP_NAME} functions must use this helper (via get_app_file or directly)
# to keep behavior 100% consistent.
# =============================================================================

resolve_app_base_dir() {
    local requested_mode="$1"
    local actual_mode="$requested_mode"
    local base_dir

    # === Volatile mode fallback chain ===
    if [ "$requested_mode" = "volatile" ]; then
        if [ -d "$VOLATILE_DIR" ] && [ -w "$VOLATILE_DIR" ]; then
            base_dir="$VOLATILE_DIR"
        elif [ -d "/tmp" ] && [ -w "/tmp" ]; then
            actual_mode="fallback"
            base_dir="/tmp"
            if [ "${QUIET}" -eq 0 ] && [ "${JSON}" -eq 0 ]; then
                warn "Volatile storage (/dev/shm) not available. Falling back to /tmp."
            fi
        else
            # Last resort: create a per-user subdirectory under /tmp
            base_dir="/tmp/${APP_NAME}_${USERNAME}"
            if ! mkdir -p "$base_dir" 2>/dev/null || [ ! -w "$base_dir" ]; then
                die "No writable temporary storage available (/dev/shm, /tmp). ${APP_NAME} cannot start."
            fi
            actual_mode="fallback"
            if [ "${QUIET}" -eq 0 ] && [ "${JSON}" -eq 0 ]; then
                warn "Volatile storage unavailable. Using fallback directory: $base_dir"
            fi
        fi
    else
        # === Persistent mode ===
        if [ -n "${HOME:-}" ] && [ -d "${HOME}" ] && [ -w "${HOME}" ]; then
            base_dir="${PERSISTENT_DIR}"
            mkdir -p "$base_dir" 2>/dev/null || true
        else
            # No usable $HOME → fallback to /tmp per-user directory
            base_dir="/tmp/${APP_NAME}_${USERNAME}_persistent"
            if ! mkdir -p "$base_dir" 2>/dev/null || [ ! -w "$base_dir" ]; then
                die "No writable location for persistent storage (no usable \$HOME and cannot write to /tmp). ${APP_NAME} cannot continue."
            fi
            if [ "${QUIET}" -eq 0 ] && [ "${JSON}" -eq 0 ]; then
                warn "No usable \$HOME detected. Persistent timers will use fallback directory: $base_dir"
            fi
        fi
    fi

    echo "$base_dir"
}

# =============================================================================
# get_app_file() - Return full path to pomo file
# =============================================================================
#
# Uses the central resolve_app_base_dir() helper to guarantee consistent
# fallback behavior and warning across the entire script.
#
# Uses the same storage resolver logic (volatile + persistent with fallbacks).
# - volatile  → /dev/shm (fast, lost on reboot)
# - persistent → ~/.cache/pomo (survives reboot)
#
# !!! DO NOT MODIFY OR SIMPLIFY THIS FUNCTION !!!
# It must remain a thin wrapper around the central resolver.
# =============================================================================

get_app_file() {
    local name="$1"
    local requested_mode="$2"
    local base_dir

    base_dir=$(resolve_app_base_dir "$requested_mode")   # Reuse existing resolver

    # App filename format guarantees per-user isolation
    echo "${base_dir}/${APP_NAME}_${USERNAME}_${name}"
}

# =============================================================================
# sanitize_name() - Prevent dangerous characters in timer names
# =============================================================================
#
# !!! DO NOT MODIFY OR SIMPLIFY THIS FUNCTION !!!
# Security / robustness measure for filename safety.
# =============================================================================

sanitize_name() {
    case "$NAME" in
        *[/\\:*?"<>|'\''"\`\$]*|*..*|*\$\(*|*${IFS}*)
            if [ "${JSON}" -eq 1 ]; then
                output_json_error "Invalid timer name: contains forbidden characters" "invalid_name"
            else
                error "Invalid timer name '${NAME}' (contains forbidden characters)"
            fi
            exit 1
            ;;
        "")
            NAME="default"
            ;;
    esac
}

# =============================================================================
# parse_duration() - Convert human duration string to seconds
# =============================================================================
#
# Supports formats:
#   25m      → 1500
#   90s      → 90
#   1h       → 3600
#   1h30m    → 5400
#   2h15m45s → 8115
#   45       → 45 (treated as seconds)
#
# Returns the number of seconds (integer) or 0 on error.
#
# !!! DO NOT SIMPLIFY THIS FUNCTION !!!
# It must remain robust against malformed input.
# =============================================================================

parse_duration() {
    local input="$1"
    local total=0
    local num

    # Empty input
    [ -z "$input" ] && echo 0 && return 0

    # If it's just a number, treat as seconds
    if printf '%s' "$input" | grep -qE '^[0-9]+$'; then
        echo "$input"
        return 0
    fi

    # Parse h/m/s components
    while [ -n "$input" ]; do
        num=$(printf '%s' "$input" | grep -oE '^[0-9]+')
        [ -z "$num" ] && echo 0 && return 0

        # Remove the number we just parsed
        input=$(printf '%s' "$input" | sed "s/^$num//")

        case "$input" in
            h* ) total=$((total + num * 3600)); input="${input#h}" ;;
            m* ) total=$((total + num * 60));   input="${input#m}" ;;
            s* ) total=$((total + num));        input="${input#s}" ;;
            *  ) echo 0; return 0 ;;   # Invalid character
        esac
    done

    echo "$total"
}

# =============================================================================
# countdown_start() - Start a new countdown timer
# =============================================================================
#
# Usage examples:
#   countdown start 25m
#   countdown start work 1h30m
#   countdown start --persist pomodoro 25m
#
# Stores: start_time target_time (in seconds)
#
# Uses atomic creation + proper existence check to avoid resetting running timers.
# Now correctly detects "already running" in both normal and --json mode.
#
# !!! DO NOT SIMPLIFY THIS LOGIC !!!
# =============================================================================

countdown_start() {
    local duration_str="$1"
    local duration_seconds
    local start_time target_time
    local mode="volatile"
    [ "$PERSIST" -eq 1 ] && mode="persistent"

    # Validate duration
    if [ -z "$duration_str" ]; then
        if [ "${JSON}" -eq 1 ]; then
            output_json_error "Duration required (e.g. 25m, 90s, 1h30m)" "missing_duration"
        else
            error "Duration is required. Example: countdown start work 25m"
        fi
        exit 1
    fi

    duration_seconds=$(parse_duration "$duration_str")
    if [ "$duration_seconds" -le 0 ]; then
        if [ "${JSON}" -eq 1 ]; then
            output_json_error "Invalid duration: ${duration_str}" "invalid_duration"
        else
            error "Invalid duration: ${duration_str}"
        fi
        exit 1
    fi

    # Check if already running
    if [ -f "$APP_FILE" ]; then
        if [ "${JSON}" -eq 1 ]; then
            output_json "error" "Countdown '${NAME}' is already running." \
                "code" "already_running" \
                "name" "$NAME" \
                "mode" "$mode"
        else
            warn "Countdown '${NAME}' is already running."
        fi
        exit 1
    fi

    # Calculate and save
    start_time=$(date +%s)
    target_time=$((start_time + duration_seconds))

    if ! printf "%s %s\n" "$start_time" "$target_time" > "$APP_FILE" 2>/dev/null; then
        if [ "${JSON}" -eq 1 ]; then
            output_json_error "Cannot create countdown file" "io_error"
        else
            error "Cannot create countdown file."
        fi
        exit 1
    fi

    # Success
    if [ "${JSON}" -eq 1 ]; then
        output_json "success" "Countdown '${NAME}' started for ${duration_str}." \
            "name" "$NAME" \
            "mode" "$mode" \
            "duration" "$duration_seconds" \
            "remaining" "$duration_seconds"
    else
        success "Countdown '${NAME}' started for ${duration_str}."
        [ "$PERSIST" -eq 1 ] && info "  (persistent mode)"
    fi
}

# =============================================================================
# countdown_stop() - Stop a countdown and show final status
# =============================================================================
#
# Stops the countdown and reports how much time was left (or if it expired).
#
# Uses APP_FILE (which was resolved via get_app_file → central fallback).
# No additional fallback code needed here.
#
# !!! DO NOT MODIFY OR SIMPLIFY !!!
# =============================================================================

countdown_stop() {
    if [ ! -f "$APP_FILE" ]; then
        if [ "${JSON}" -eq 1 ]; then
            output_json_error "No countdown '${NAME}' running." "no_countdown"
        else
            warn "No countdown '${NAME}' running."
        fi
        exit 1
    fi

    local start_time target_time current_time remaining
    local minutes seconds
    local actual_mode="volatile"
    [ "$PERSIST" -eq 1 ] && actual_mode="persistent"

    read -r start_time target_time < "$APP_FILE" 2>/dev/null || {
        if [ "${JSON}" -eq 1 ]; then
            output_json_error "Corrupted countdown file" "corrupted_data"
        else
            error "Corrupted countdown file."
        fi
        exit 1
    }

    current_time=$(date +%s)
    remaining=$((target_time - current_time))

    if [ "$remaining" -gt 0 ]; then
        minutes=$((remaining / 60))
        seconds=$((remaining % 60))
    else
        minutes=0
        seconds=0
    fi

    # Remove the file
    rm -f "$APP_FILE"

    if [ "${JSON}" -eq 1 ]; then
        if [ "$remaining" -gt 0 ]; then
            output_json "success" "Countdown '${NAME}' stopped with ${minutes} min ${seconds} sec remaining." \
                "name" "$NAME" \
                "mode" "$actual_mode" \
                "duration" "$((target_time - start_time))" \
                "remaining" "$remaining" \
                "minutes" "$minutes" \
                "seconds" "$seconds"
        else
            output_json "success" "Countdown '${NAME}' stopped (already expired)." \
                "name" "$NAME" \
                "mode" "$actual_mode" \
                "duration" "$((target_time - start_time))" \
                "remaining" "0" \
                "expired" "true"
        fi
    else
        if [ "$remaining" -gt 0 ]; then
            success "Countdown '${NAME}' stopped with ${minutes} min ${seconds} sec remaining."
        else
            success "Countdown '${NAME}' stopped (already expired)."
        fi
    fi
}

# =============================================================================
# countdown_status() - Show remaining time of a countdown
# =============================================================================
#
# Automatically removes the timer file if it has expired.
# =============================================================================

countdown_status() {
    if [ ! -f "$APP_FILE" ]; then
        if [ "${JSON}" -eq 1 ]; then
            output_json_error "No countdown '${NAME}' running." "no_countdown"
        else
            warn "No countdown '${NAME}' running."
        fi
        exit 1
    fi

    local start_time target_time current_time remaining
    local minutes seconds

    read -r start_time target_time < "$APP_FILE" 2>/dev/null || {
        if [ "${JSON}" -eq 1 ]; then
            output_json_error "Corrupted countdown file" "corrupted_data"
        else
            error "Corrupted countdown file."
        fi
        rm -f "$APP_FILE" 2>/dev/null || true
        exit 1
    }

    current_time=$(date +%s)
    remaining=$((target_time - current_time))

    local actual_mode="volatile"
    [ "$PERSIST" -eq 1 ] && actual_mode="persistent"

    if [ "$remaining" -le 0 ]; then
        rm -f "$APP_FILE" 2>/dev/null || true
        if [ "${JSON}" -eq 1 ]; then
            output_json "status" "Countdown '${NAME}' has expired." \
                "name" "$NAME" \
                "mode" "$actual_mode" \
                "duration" "$((target_time - start_time))" \
                "remaining" "0" \
                "expired" "true"
        else
            warn "Countdown '${NAME}' has expired."
        fi
        return 0
    fi

    # Still running
    minutes=$((remaining / 60))
    seconds=$((remaining % 60))

    if [ "${JSON}" -eq 1 ]; then
        output_json "status" "Countdown '${NAME}' running." \
            "name" "$NAME" \
            "mode" "$actual_mode" \
            "duration" "$((target_time - start_time))" \
            "remaining" "$remaining" \
            "minutes" "$minutes" \
            "seconds" "$seconds"
    else
        msg "Countdown '${NAME}': ${minutes} min ${seconds} sec remaining"
    fi
}

# =============================================================================
# list_countdown() - List all running timers for current user
# =============================================================================
#
# Now automatically cleans up expired timers when listing.
# Uses the central resolve_app_base_dir() helper.
# Only shows timers that still have remaining time > 0.
#
# !!! DO NOT MODIFY OR SIMPLIFY !!!
# =============================================================================

list_countdown() {
    local requested_mode="$1"
    local base_dir timers_json count=0 file name start_time target_time current_time remaining minutes seconds

    base_dir=$(resolve_app_base_dir "$requested_mode")

    if [ ! -d "$base_dir" ]; then
        if [ "${JSON}" -eq 1 ]; then
            output_json "list" "" "mode" "$requested_mode" "count" "0" "timers" "[]"
        else
            msg "No running countdowns found."
        fi
        return 0
    fi

    timers_json="["
    local first=true

    for file in "${base_dir}"/countdown_"${USERNAME}"_*; do
        [ -f "$file" ] || continue

        name="${file##*countdown_${USERNAME}_}"

        # Read start and target time
        if ! read -r start_time target_time < "$file" 2>/dev/null; then
            rm -f "$file" 2>/dev/null || true
            continue
        fi

        current_time=$(date +%s 2>/dev/null) || continue
        remaining=$((target_time - current_time))

        if [ "$remaining" -le 0 ]; then
            # Auto-cleanup expired timer
            rm -f "$file" 2>/dev/null || true
            continue
        fi

        # Timer is still running
        minutes=$((remaining / 60))
        seconds=$((remaining % 60))

        if [ "$count" -gt 0 ]; then
            timers_json="${timers_json},"
        fi

        timers_json="${timers_json}{\"name\":\"${name}\",\"duration\":$((target_time - start_time)),\"remaining\":${remaining},\"minutes\":${minutes},\"seconds\":${seconds}}"
        count=$((count + 1))
    done
    timers_json="${timers_json}]"

    if [ "${JSON}" -eq 1 ]; then
        output_json "list" "" \
            "mode" "$requested_mode" \
            "count" "$count" \
            "timers" "$timers_json"
    else
        if [ "$count" -eq 0 ]; then
            msg "No running countdowns found."
        else
            for file in "${base_dir}"/countdown_"${USERNAME}"_*; do
                [ -f "$file" ] || continue
                name="${file##*countdown_${USERNAME}_}"
                if ! read -r start_time target_time < "$file" 2>/dev/null; then
                    rm -f "$file" 2>/dev/null || true
                    continue
                fi
                current_time=$(date +%s)
                remaining=$((target_time - current_time))
                if [ "$remaining" -le 0 ]; then
                    rm -f "$file" 2>/dev/null || true
                    continue
                fi
                minutes=$((remaining / 60))
                seconds=$((remaining % 60))
                msg "${name}: ${minutes} min ${seconds} sec remaining"
            done
        fi
    fi
}

# =============================================================================
# main_countdown() - Main dispatcher for the countdown tool
# =============================================================================
#
# Handles argument parsing and routes to the correct countdown functions.
# Supports the desired syntax:
#   countdown start [--persist] [name] <duration>
#   countdown status [--persist] [name]
#   countdown stop|kill|reset [--persist] [name]
#   countdown list [--persist]
#
# IMPORTANT DESIGN DECISION:
#   The auto-install logic (`maybe_install_v3` / `perform_self_install_v2`) is triggered
#   when the script is run with ZERO arguments via `curl | sh`.
#
#   This is INTENTIONAL and CRITICAL for the one-liner installer to work.
#   Without it, `curl -fsSL ... | sh` would only print help and exit, leaving
#   the user with "command not found" — exactly the problem we are solving.
#
#   Even though subcommands like "help", "version", or "about" exist,
#   we still want to check/install first in the curl | sh context because
#   the primary use-case of piping the raw script is installation.
#
#   This pattern is common in robust single-file CLI tools and must be preserved.
#
# !!! DO NOT REMOVE OR SIMPLIFY THE AUTO-INSTALL BLOCK !!!
#   Many AI assistants will try to "clean it up", move it after parsing,
#   or tie it only to specific subcommands.
#   Doing so would break the one-liner installation experience (`curl | sh`),
#   which is one of the core promises of this project.
#
#   Previous Grok versions already attempted to remove or relocate this logic.
#   Respect this decision and keep the auto-install check at the top, before
#   any argument parsing.
# =============================================================================

main_countdown() {
    local cmd="help"
    local NAME="default"
    local PERSIST=0
    local DURATION=""

    # === AUTO-INSTALL FOR ONE-LINER (curl | sh) ===
    # This block MUST stay at the very top, before any argument parsing.
    # It ensures that `curl ... | sh` actually installs the tool instead of
    # just showing help and exiting with "command not found".
    #
    # perform_self_install_v2 / maybe_install_v3 is important here EVEN THOUGH
    # a subcommand may be present later, because the main real-world usage
    # of this script is the one-liner installer. Installing first is the
    # expected behavior in that context.
    if ! is_installed && [ $# -eq 0 ]; then
        if [ "${JSON}" -eq 1 ] || [ "${QUIET}" -eq 1 ]; then
            # Non-interactive / JSON mode → install silently
            perform_self_install_v2
        else
            maybe_install_v3
        fi
        exit 0
    fi

    # === Phase 1: Parse all arguments (fixed start command) ===
    while [ $# -gt 0 ]; do
        case "$1" in
            --persist)
                PERSIST=1
                ;;
            --quiet|-q)
                QUIET=1
                ;;
            --json)
                JSON=1
                QUIET=1
                ;;
            start|stop|status|list|kill|reset)
                cmd="$1"
                ;;
            help|version|about|version-check|self-update|self-uninstall)
                cmd="${1#--}"
                ;;
            *)
                # Handle positional arguments for 'start' and other commands
                if [ "$cmd" = "start" ]; then
                    # Check if this argument looks like a duration
                    if printf '%s' "$1" | grep -qE '^[0-9]+[hms]?([0-9]+[hms]?)*$|^[0-9]+$'; then
                        if [ -z "$DURATION" ]; then
                            DURATION="$1"
                        else
                            if [ "${JSON}" -eq 1 ]; then
                                output_json_error "Too many arguments for start command" "bad_argument"
                            else
                                error "Too many arguments for start command."
                            fi
                            exit 1
                        fi
                    else
                        if [ "$NAME" = "default" ]; then
                            NAME="$1"
                        else
                            if [ "${JSON}" -eq 1 ]; then
                                output_json_error "Too many arguments for start command" "bad_argument"
                            else
                                error "Too many arguments for start command."
                            fi
                            exit 1
                        fi
                    fi
                else
                    # For status/stop/kill/reset/list: the argument is the name
                    NAME="$1"
                fi
                ;;
        esac
        shift
    done

    # === Validation for start command ===
    if [ "$cmd" = "start" ] && [ -z "$DURATION" ]; then
        if [ "${JSON}" -eq 1 ]; then
            output_json_error "Duration required (e.g. 25m, 90s, 1h30m)" "missing_duration"
        else
            error "Duration is required for 'start' command. Example: countdown start work 25m"
        fi
        exit 1
    fi

    # === Sanitize timer NAME (only if it's a countdown operation) ===
    if [ "$cmd" = "start" ] || [ "$cmd" = "stop" ] || [ "$cmd" = "status" ] || \
       [ "$cmd" = "kill" ] || [ "$cmd" = "reset" ] || [ "$cmd" = "list" ]; then
        sanitize_name
    fi

    # Determine storage mode and file path
    local STORAGE_MODE
    STORAGE_MODE=$([ "$PERSIST" -eq 1 ] && echo "persistent" || echo "volatile")
    APP_FILE=$(get_app_file "$NAME" "$STORAGE_MODE")

    # === Phase 2: Dispatch commands ===
    case "$cmd" in
        start)
            countdown_start "$DURATION"
            ;;

        status)
            countdown_status
            ;;

        stop)
            countdown_stop
            ;;

        kill|reset)
            if [ ! -f "$APP_FILE" ]; then
                if [ "${JSON}" -eq 1 ]; then
                    output_json_error "No countdown '${NAME}' running." "no_countdown"
                else
                    warn "No countdown '${NAME}' running."
                fi
                exit 1
            fi
            rm -f "$APP_FILE"
            if [ "${JSON}" -eq 1 ]; then
                output_json "success" "Countdown '${NAME}' has been discarded." \
                    "name" "$NAME" \
                    "mode" "$STORAGE_MODE"
            else
                if [ "$cmd" = "reset" ]; then
                    success "Countdown '${NAME}' has been reset."
                else
                    warn "Countdown '${NAME}' has been discarded."
                fi
            fi
            ;;

        list)
            list_countdown "$STORAGE_MODE"
            ;;

        about)
            show_about
            ;;

        version)
            if [ "${JSON}" -eq 1 ]; then
                output_json "version" "" \
                    "app" "${APP_NAME}" \
                    "version" "${VERSION}"
            else
                msg "${APP_NAME} version ${VERSION}"
            fi
            ;;

        version-check)
            version_check
            ;;

        self-update)
            self_update_v3
            ;;

        self-uninstall)
            self_uninstall_v2
            ;;

        help|*)
            show_countdown_help
            ;;
    esac
}

main_countdown "$@"