# =============================================================================

msg_n() {
    output_text "plain_n" "$*"
}

# =============================================================================
# Updated thin wrapper functions - All output must go through output_text()
# =============================================================================

die() {
    if [ "${JSON}" -eq 1 ]; then
        output_json_error "$*"
    else
        output_text "error" "$*"
    fi
    exit 1
}

info() {
    output_text "info" "$*"
}

success() {
